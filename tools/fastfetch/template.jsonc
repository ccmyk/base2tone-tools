{
  "display": {
    "color": {
      "keys": "#{{B4}}",
      "title": "#{{C6}}",
      "output": "#{{C5}}",
      "separator": "#{{A3}}"
    },

    "bar": {
      "color": {
        "elapsed": "#{{D4}}",
        "total": "#{{A3}}",
        "border": "#{{A4}}"
      }
    },

    "percent": {
      "color": {
        "green": "#{{D4}}",
        "yellow": "#{{D6}}",
        "red": "#{{B4}}"
      }
    }
  }
}