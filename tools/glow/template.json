{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#{{C6}}",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "\u2502 ",
    "color": "#{{A5}}"
  },
  "paragraph": {
    "color": "#{{C6}}"
  },
  "list": {
    "level_indent": 2,
    "color": "#{{C6}}"
  },
  "heading": {
    "block_suffix": "\n",
    "bold": true,
    "color": "#{{C7}}"
  },
  "h1": {
    "prefix": "# ",
    "color": "#{{D7}}",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "#{{D6}}",
    "bold": true
  },
  "h3": {
    "prefix": "### ",
    "color": "#{{B6}}",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "color": "#{{B5}}",
    "bold": true
  },
  "h5": {
    "prefix": "##### ",
    "color": "#{{C7}}",
    "bold": true
  },
  "h6": {
    "prefix": "###### ",
    "color": "#{{A6}}"
  },
  "text": {
    "color": "#{{C6}}"
  },
  "strikethrough": {
    "color": "#{{A4}}",
    "crossed_out": true
  },
  "emph": {
    "color": "#{{C6}}",
    "italic": true
  },
  "strong": {
    "color": "#{{C7}}",
    "bold": true
  },
  "hr": {
    "color": "#{{A4}}",
    "format": "\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n"
  },
  "item": {
    "block_prefix": "\u2022 ",
    "color": "#{{B5}}"
  },
  "enumeration": {
    "block_prefix": ". ",
    "color": "#{{B5}}"
  },
  "task": {
    "ticked": "[x] ",
    "unticked": "[ ] ",
    "color": "#{{C6}}"
  },
  "link": {
    "color": "#{{B6}}",
    "underline": true
  },
  "link_text": {
    "color": "#{{C7}}",
    "bold": true
  },
  "image": {
    "color": "#{{B5}}",
    "underline": true
  },
  "image_text": {
    "color": "#{{A5}}",
    "format": "Image: {{.text}} \u2192"
  },
  "code": {
    "prefix": "\u00a0",
    "suffix": "\u00a0",
    "color": "#{{D7}}",
    "background_color": "#{{A1}}"
  },
  "code_block": {
    "color": "#{{C6}}",
    "margin": 2,
    "chroma": {
      "text": {
        "color": "#{{C6}}"
      },
      "error": {
        "color": "#{{C7}}",
        "background_color": "#{{B2}}"
      },
      "comment": {
        "color": "#{{A4}}"
      },
      "comment_preproc": {
        "color": "#{{A5}}"
      },
      "keyword": {
        "color": "#{{D6}}",
        "bold": true
      },
      "keyword_reserved": {
        "color": "#{{D5}}"
      },
      "keyword_namespace": {
        "color": "#{{D5}}"
      },
      "keyword_type": {
        "color": "#{{B6}}"
      },
      "operator": {
        "color": "#{{A6}}"
      },
      "punctuation": {
        "color": "#{{A5}}"
      },
      "name": {
        "color": "#{{C6}}"
      },
      "name_builtin": {
        "color": "#{{B6}}"
      },
      "name_tag": {
        "color": "#{{D5}}"
      },
      "name_attribute": {
        "color": "#{{B5}}"
      },
      "name_class": {
        "color": "#{{C7}}",
        "bold": true
      },
      "name_constant": {
        "color": "#{{D5}}"
      },
      "name_decorator": {
        "color": "#{{D6}}"
      },
      "name_exception": {
        "color": "#{{B2}}",
        "bold": true
      },
      "name_function": {
        "color": "#{{B6}}"
      },
      "name_other": {
        "color": "#{{C6}}"
      },
      "literal": {
        "color": "#{{C6}}"
      },
      "literal_number": {
        "color": "#{{D5}}"
      },
      "literal_date": {
        "color": "#{{D5}}"
      },
      "literal_string": {
        "color": "#{{B6}}"
      },
      "literal_string_escape": {
        "color": "#{{D7}}"
      },
      "generic_deleted": {
        "color": "#{{B2}}"
      },
      "generic_emph": {
        "color": "#{{C6}}",
        "italic": true
      },
      "generic_inserted": {
        "color": "#{{D5}}"
      },
      "generic_strong": {
        "color": "#{{C7}}",
        "bold": true
      },
      "generic_subheading": {
        "color": "#{{B6}}"
      },
      "background": {
        "background_color": "#{{A1}}"
      }
    }
  },
  "table": {
    "color": "#{{C6}}",
    "center_separator": "\u253c",
    "column_separator": "\u2502",
    "row_separator": "\u2500"
  },
  "definition_list": {
    "color": "#{{C6}}"
  },
  "definition_term": {
    "color": "#{{B6}}",
    "bold": true
  },
  "definition_description": {
    "block_prefix": "\n  ",
    "color": "#{{C6}}"
  },
  "html_block": {
    "color": "#{{A5}}"
  },
  "html_span": {
    "color": "#{{A5}}"
  }
}
