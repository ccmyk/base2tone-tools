#!/usr/bin/env python3

from __future__ import annotations

import argparse
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent

if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.compiler import (  # noqa: E402
    ROOT,
    ThemeError,
    build_active,
    discover_modules,
    list_schemes,
    load_palette,
)


def command_list() -> int:
    for scheme in list_schemes():
        print(scheme)

    return 0


def command_validate(scheme: str) -> int:
    palette = load_palette(scheme)
    modules = discover_modules()

    print(f"Scheme:      {palette.name}")
    print(f"Source:      {palette.source}")
    print(f"Coordinates: {len(palette.colors)}")
    print(
        "Modules:     "
        + ", ".join(module.name for module in modules)
    )
    print("Status:      valid")

    return 0


def command_build(scheme: str) -> int:
    result = build_active(scheme)

    print(f"Scheme: {result.palette.name}")
    print(f"Source: {result.palette.source}")
    print(
        "Modules: "
        + ", ".join(module.name for module in result.modules)
    )

    for output in result.outputs:
        print(f"Generated: {output.relative_to(ROOT)}")

    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="b2t-theme",
        description=(
            "Build tool-native themes directly from "
            "Base2Tone coordinates."
        ),
    )

    subparsers = parser.add_subparsers(
        dest="command",
        required=True,
    )

    subparsers.add_parser(
        "list",
        help="list available Base2Tone schemes",
    )

    validate_parser = subparsers.add_parser(
        "validate",
        help="validate a scheme and discover tool modules",
    )
    validate_parser.add_argument("scheme")

    build_parser = subparsers.add_parser(
        "build",
        help="build one active theme set",
    )
    build_parser.add_argument("scheme")

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    try:
        if args.command == "list":
            return command_list()

        if args.command == "validate":
            return command_validate(args.scheme)

        if args.command == "build":
            return command_build(args.scheme)

        parser.error(f"Unknown command: {args.command}")

    except ThemeError as error:
        print(f"error: {error}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
